generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Node {
  id          String   @id @default(cuid())
  nodeKey     String   @unique
  displayName String
  category    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  executions  ExecutionEvent[]
}

model ExecutionEvent {
  id            String   @id @default(cuid())

  nodeId        String
  node          Node     @relation(fields: [nodeId], references: [id])

  executionType String
  status        String

  inputSummary  String?
  outputSummary String?

  createdAt     DateTime @default(now())
}

model CapabilityPlan {
  id            String   @id @default(cuid())

  requestText   String
  plannerOutput Json

  createdAt     DateTime @default(now())
}

model MemoryRecord {
  id            String   @id @default(cuid())

  memoryType    String
  memoryKey     String

  payload       Json

  createdAt     DateTime @default(now())

  @@index([memoryType])
  @@index([memoryKey])
}

model AuditEvent {
  id            String   @id @default(cuid())

  eventType     String
  eventSource   String

  payload       Json

  createdAt     DateTime @default(now())
}

model KgxRelationship {
  id           String   @id @default(cuid())

  sourceType   String
  sourceId     String

  relationType String

  targetType   String
  targetId     String

  payload      Json?

  createdAt    DateTime @default(now())

  @@index([sourceType])
  @@index([sourceId])
  @@index([relationType])
  @@index([targetType])
  @@index([targetId])
}
